{
    "version": 2,
    "buildCommand": "npm run build:client",
    "outputDirectory": "dist",
    "functions": {
        "api/index.ts": {
            "includeFiles": "server/**,shared/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}