{
    "version": 2,
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/opportunites/(.*)",
            "destination": "/api"
        },
        {
            "source": "/formations/(.*)",
            "destination": "/api"
        },
        {
            "source": "/evenements/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!api/|locales/).*)",
            "destination": "/index.html"
        }
    ]
}